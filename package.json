{
  "name": "yzj",
  "version": "2026.4.8",
  "type": "module",
  "description": "OpenClaw YZJ (Yunzhijia) intelligent bot channel plugin",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "yzj",
      "label": "YZJ Robot",
      "selectionLabel": "YZJ Robot (plugin)",
      "detailLabel": "YZJ Robot",
      "docsPath": "/channels/yzj",
      "docsLabel": "yzj",
      "blurb": "YunZiJia intelligent bot via HTTP API + webhooks with streaming support.",
      "aliases": [
        "yunzhijia",
        "yzj",
        "云之家",
        "云之家机器人"
      ],
      "order": 90
    },
    "install": {
      "localPath": "extensions/yzj",
      "defaultChoice": "npm"
    }
  },
  "clawdbot": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "yzj",
      "label": "YZJ Robot",
      "selectionLabel": "YZJ Robot (plugin)",
      "detailLabel": "YZJ Robot",
      "docsPath": "/channels/yzj",
      "docsLabel": "yzj",
      "blurb": "YunZiJia intelligent bot via HTTP API + webhooks with streaming support.",
      "aliases": [
        "yunzhijia",
        "yzj",
        "云之家",
        "云之家机器人"
      ],
      "order": 90
    },
    "install": {
      "localPath": "extensions/yzj",
      "defaultChoice": "npm"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.24"
  },
  "scripts": {
    "test": "node --test --experimental-strip-types test/*.test.ts"
  },
  "files": [
    "index.ts",
    "src/**/*",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  }
}
